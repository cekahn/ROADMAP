        skos:altLabel "facility count"@en,
        skos:altLabel "number of facilities"@en,
        skos:altLabel "number of imaging facilities"@en,
        skos:altLabel "number of sites"@en,
        skos:definition "Number of distinct imaging sites, i.e., imaging facilities."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00055
    
    
Class: roadmap:ROADMAP_03359

