        dc:source <https://doi.org/10.1148/radiol.220182>,
        rdfs:label "curva precisión-exhaustividad"@es,
        rdfs:label "precision-recall curve"@en,
        rdfs:label "精确率-召回率曲线"@zh,
        skos:altLabel "P-R curve"@en,
        skos:altLabel "PR curve"@en,
        skos:altLabel "precision recall curve"@en,
        skos:altLabel "precision-recall analysis"@en,
        skos:definition "The precision–recall curve (PRC) plots precision on the y-axis against recall on the x-axis at varying thresholds."@en
    
