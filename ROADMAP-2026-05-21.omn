        rdfs:label "Davies-Bouldin 指数"@zh,
        rdfs:label "índice de Davies-Bouldin"@es,
        skos:altLabel "DBI"@en,
        skos:definition "The Davies–Bouldin index (DBI) is a metric for evaluating clustering algorithms, where the validation of how well the clustering has been done is made using quantities and features inherent to the dataset."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_00145
    
    
