    Annotations: 
        rdfs:comment "Examples of regions of interest:
* 1D dataset: a time or frequency interval on a waveform
* 2D dataset: the boundaries of an object on an image
* 3D dataset: the contours or surfaces outlining an object (sometimes known as the Volume of Interest (VOI)) in a volume
* 4D dataset: the outline of an object at or during a particular time interval in a time-volume"@en,
        rdfs:label "anotación de la región de interés"@es,
        rdfs:label "region-of-interest annotation"@en,
        rdfs:label "感兴趣区域标注"@zh,
        skos:altLabel "ROI annotation"@en,
        skos:altLabel "ROI label"@en,
        skos:altLabel "region of interest annotation"@en,
        skos:altLabel "region of interest label"@en,
        skos:altLabel "region-of-interest label"@en,
        skos:definition "Annotation applied to a subset of a planar image or image volume."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03479
    
    
Class: roadmap:ROADMAP_03365

    Annotations: 
