    Annotations: 
        dc:source <https://doi.org/10.1186/s12916-019-1466-7>,
        rdfs:label "calibration curve"@en,
        rdfs:label "curva de calibración"@es,
        rdfs:label "校准曲线"@zh,
        rdfs:seeAlso <https://en.wikipedia.org/wiki/Calibration_curve>,
        skos:altLabel "calibration"@en,
        skos:altLabel "calibration analysis"@en,
        skos:definition "Calibration in statistical modeling refers to the agreement between predicted probabilities and observed outcomes. A well-calibrated model will have predicted probabilities that match the empirical frequencies of events."@en
    
    SubClassOf: 
