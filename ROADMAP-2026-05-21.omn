    Annotations: 
        dc:source <https://doi.org/10.1117/1.JMI.11.2.024504>,
        rdfs:label "tiempo para el ajuste por parte del usuario"@es,
        rdfs:label "time for user adjustment"@en,
        rdfs:label "用户调整时间"@zh,
        skos:definition "Time for user adjustment reflects the duration required to manually review and modify an algorithm’s outputs before acceptance. It provides insight into the usability and efficiency of the system in a clinical setting. Longer times may indicate higher interaction burden or workflow inefficiency."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04066
    
    
Class: roadmap:ROADMAP_03692

    Annotations: 
        dc:source <https://doi.org/10.1117/1.JMI.11.2.024504>,
        rdfs:label "incertidumbre asociada a la interacción con el usuario"@es,
        rdfs:label "uncertainty associated with user interaction"@en,
        rdfs:label "与用户交互相关的不确定性"@zh,
        skos:definition "Uncertainty associated with user interaction describes the additional variability introduced when manual adjustments or user decisions affect an algorithm’s output. This measure accounts for operator-dependent factors in performance evaluation. It highlights the combined impact of algorithmic and human components on overall reliability."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
