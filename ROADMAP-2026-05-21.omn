        roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00024

    Annotations: 
        rdfs:label "image processing"@en,
        rdfs:label "procesamiento de imágenes"@es,
        rdfs:label "图像处理"@zh,
        skos:definition "Use of an AI model for image processing, such as image reconstruction, style transfer, or noise reduction."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00025

    Annotations: 
        rdfs:label "image reconstruction"@en,
        rdfs:label "reconstrucción de imágenes"@es,
        rdfs:label "图像重建"@zh,
        skos:definition "image reconstruction refers to the construction of a target domain image from source domain signals, which could be divided into raw-to-image and postprocessing applications."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00024
    
    
Class: roadmap:ROADMAP_00026

    Annotations: 
