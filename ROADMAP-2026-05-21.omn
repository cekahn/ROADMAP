Class: roadmap:ROADMAP_00001

    Annotations: 
        rdfs:label "ROADMAP entity"@en,
        rdfs:label "ROADMAP 实体"@zh,
        rdfs:label "entidad de ontología ROADMAP"@es,
        skos:definition "The top-level class in the ROADMAP ontology."@en
    
    SubClassOf: 
        owl:Thing
    
    
Class: roadmap:ROADMAP_00002

    Annotations: 
        rdfs:label "model"@en,
        rdfs:label "modelo"@es,
        rdfs:label "模型"@zh,
        skos:definition "An AI model, described by descriptors and model properties."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00001,
        roadmap:ROADMAP_00116 some roadmap:ROADMAP_00004,
        roadmap:ROADMAP_00629 some roadmap:ROADMAP_00011,
        roadmap:ROADMAP_00630 some roadmap:ROADMAP_00036,
        roadmap:ROADMAP_00631 some roadmap:ROADMAP_00074,
        roadmap:ROADMAP_03300 some roadmap:ROADMAP_03598,
        roadmap:ROADMAP_03350 some roadmap:ROADMAP_03355,
        roadmap:ROADMAP_03644 some roadmap:ROADMAP_03642
    
    
Class: roadmap:ROADMAP_00003

    Annotations: 
        rdfs:label "conjunto de datos"@es,
        rdfs:label "dataset"@en,
        rdfs:label "数据集"@zh,
        skos:definition "A collection of data used to train and/or test an AI model."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00001,
        roadmap:ROADMAP_00631 some roadmap:ROADMAP_00074,
        roadmap:ROADMAP_03382 some roadmap:ROADMAP_03381
    
    
Class: roadmap:ROADMAP_00004

    Annotations: 
        rdfs:label "descriptor"@en,
        rdfs:label "descriptor"@es,
        rdfs:label "描述符"@zh,
        skos:altLabel "detail"@en,
        skos:altLabel "details"@en,
        skos:altLabel "detalles"@es,
        skos:altLabel "resource descriptor"@en,
        skos:definition "A characteristic of a project, model, or dataset.  Whenever possible, values should link to other ontologies or controlled vocabularies."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00001
    
    
Class: roadmap:ROADMAP_00005

    Annotations: 
        rdfs:label "conjunto de datos de entrenamiento"@es,
        rdfs:label "training dataset"@en,
        rdfs:label "训练数据集"@zh,
        skos:altLabel "training data"@en,
        skos:definition "The data on which an AI model is trained."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00003
    
    
Class: roadmap:ROADMAP_00006

    Annotations: 
        rdfs:label "conjunto de datos de optimización"@es,
        rdfs:label "optimization dataset"@en,
        rdfs:label "优化数据集"@zh,
        skos:altLabel "optimization data"@en,
        skos:altLabel "tuning data"@en,
        skos:altLabel "tuning dataset"@en,
        skos:altLabel "validation data"@en,
        skos:altLabel "validation dataset"@en,
        skos:definition "A dataset used to \"tune\" or optimize the performance of an AI model. Deep learning systems often use the term \"validation,\" but in medical applications, it can be confused with clinical validation. Hence, \"optimization\" is preferred."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00003
    
    
Class: roadmap:ROADMAP_00007

    Annotations: 
        rdfs:label "conjunto de datos de prueba"@es,
        rdfs:label "testing dataset"@en,
        rdfs:label "测试数据集"@zh,
        skos:altLabel "testing data"@en,
        skos:definition "Data on which a model's performance is assessed. Can be \"internal\" (a partition of the original dataset) or \"external\" (from another dataset or institution)."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00003
    
    
Class: roadmap:ROADMAP_00008

    Annotations: 
        rdfs:label "conjunto de datos de pruebas internas"@es,
        rdfs:label "internal testing dataset"@en,
        rdfs:label "内部测试数据集"@zh,
        skos:altLabel "internal test data"@en,
        skos:altLabel "internal test dataset"@en,
        skos:altLabel "internal testing data"@en,
        skos:definition "Data from the same institution and setting as the training and/or optimization datasets used to evaluate the model's performance. Often these data are a partition of the original (internal) dataset used to train and optimize a model."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00007
    
    
Class: roadmap:ROADMAP_00009

    Annotations: 
        rdfs:comment "The term \"external testing\" is preferred over \"external validation,\" as the term \"validation\" can be ambiguous."@en,
        rdfs:label "conjunto de datos de pruebas externas"@es,
        rdfs:label "external testing dataset"@en,
        rdfs:label "外部测试数据集"@zh,
        skos:altLabel "external testing data"@en,
        skos:altLabel "external testing dataset"@en,
        skos:altLabel "external validation data"@en,
        skos:altLabel "external validation dataset"@en,
        skos:definition "Data on which a model's performance is assessed; the data should be from another institution or setting."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00007
    
    
Class: roadmap:ROADMAP_00010

    Annotations: 
        rdfs:label "project"@en,
        rdfs:label "proyecto"@es,
        rdfs:label "项目"@zh,
        skos:definition "A Project allows one to aggregate Models and Datasets;  a Project can comprise a model and its data, a model only, or a dataset only. It is described by Descriptor entities (Author, Date, Comments, etc.)."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00001,
        roadmap:ROADMAP_00114 some roadmap:ROADMAP_00002,
        roadmap:ROADMAP_00115 some roadmap:ROADMAP_00003,
        roadmap:ROADMAP_00116 some roadmap:ROADMAP_00004,
        roadmap:ROADMAP_00631 some roadmap:ROADMAP_00074
    
    
Class: roadmap:ROADMAP_00011

    Annotations: 
        rdfs:label "model use"@en,
        rdfs:label "uso del modelo"@es,
        rdfs:label "模型用途"@zh,
        skos:definition "The ways in which a model is used: can include intended uses, out-of-scope uses, and excluded uses."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03355,
        roadmap:ROADMAP_00198 some roadmap:ROADMAP_00244,
        roadmap:ROADMAP_00631 some roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00012

    Annotations: 
        rdfs:label "intended model use"@en,
        rdfs:label "uso previsto del modelo"@es,
        rdfs:label "预期模型用途"@zh,
        skos:definition "An intended model use is the application of an AI model to tasks, data, or environments for which it has been designed."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00011
    
    
Class: roadmap:ROADMAP_00013

    Annotations: 
        rdfs:label "out-of-scope model use"@en,
        rdfs:label "uso fuera del alcance del modelo"@es,
        rdfs:label "超出范围的模型使用"@zh,
        skos:definition "Out-of-scope model use refers to applying a machine learning model, AI system, or project deliverable to tasks, data, or environments outside its intended design, original requirements, or training distribution."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00011
    
    
Class: roadmap:ROADMAP_00014

    Annotations: 
        rdfs:label "excluded model use"@en,
        rdfs:label "uso excluido del modelo"@es,
        rdfs:label "排除的模型使用"@zh,
        skos:definition "An excluded model use is the application of an AI model to tasks, data, or environments where it should not be used."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00011
    
    
Class: roadmap:ROADMAP_00015

    Annotations: 
        rdfs:label "tipo de uso"@es,
        rdfs:label "use type"@en,
        rdfs:label "使用类型"@zh,
        skos:altLabel "task"@en,
        skos:definition "The type of task to which the AI model is applied, such as image segmentation."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00001
    
    
Class: roadmap:ROADMAP_00016

    Annotations: 
        rdfs:label "evaluación de riesgos"@es,
        rdfs:label "risk assessment"@en,
        rdfs:label "风险评估"@zh,
        skos:definition "Prediction of the likelihood of a specified condition or occurrence."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00017

    Annotations: 
        rdfs:label "procedure selection"@en,
        rdfs:label "selección del procedimiento"@es,
        rdfs:label "程序选择"@zh,
        skos:definition "Selection of a procedure, notably an imaging procedure, that is most appropriate to answer a clinical question."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00018

    Annotations: 
        rdfs:label "exam protocol selection"@en,
        rdfs:label "selección del protocolo de examen"@es,
        rdfs:label "检查方案选择"@zh,
        skos:altLabel "protocol selection"@en,
        skos:altLabel "protocoling"@en,
        skos:definition "Specification of the details of the examination, such as imaging sequences, type of contrast media, etc."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00019

    Annotations: 
        rdfs:label "triage"@en,
        rdfs:label "triaje"@es,
        rdfs:label "分诊"@zh,
        skos:altLabel "CADt"@en,
        skos:altLabel "Computer-aided triage"@en,
        skos:altLabel "Computer-assisted triage"@en,
        skos:altLabel "Computer-assisted triage and notification"@en,
        skos:definition "Use of an AI system to determine the order in which examinations should be performed and/or interpreted."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00020

    Annotations: 
        rdfs:label "detección"@es,
        rdfs:label "detection"@en,
        rdfs:label "检测"@zh,
        skos:altLabel "CADe"@en,
        skos:altLabel "computer-aided detection"@en,
        skos:altLabel "computer-assisted detection"@en,
        skos:definition "Use of an AI system to detect one or more disorders or conditions."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03638
    
    
Class: roadmap:ROADMAP_00021

    Annotations: 
        rdfs:label "diagnosis"@en,
        rdfs:label "diagnóstico"@es,
        rdfs:label "诊断"@zh,
        skos:altLabel "CADx"@en,
        skos:altLabel "computer-aided diagnosis"@en,
        skos:altLabel "computer-assisted diagnosis"@en,
        skos:altLabel "computer-assisted diagnostic"@en,
        skos:definition "Identification of a single diagnosis or a list of possible diagnoses."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03638
    
    
Class: roadmap:ROADMAP_00022

    Annotations: 
        rdfs:label "apoyo a la toma de decisiones"@es,
        rdfs:label "decision support"@en,
        rdfs:label "决策支持"@zh,
        skos:definition "Use of an AI system to aid in medical decision making."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00015
    
    
Class: roadmap:ROADMAP_00023

    Annotations: 
        rdfs:label "prognosis"@en,
        rdfs:label "pronóstico"@es,
        rdfs:label "预后"@zh,
        skos:definition "A prognosis is a medical prediction of the likely course and outcome of a disease, including recovery chances, symptom improvement, and survival."@en
    
