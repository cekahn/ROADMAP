    Annotations: 
        dc:source <https://apps.dtic.mil/sti/html/tr/AD0667273/>,
        dc:source <https://readable.com/readability/automated-readability-index/>,
        rdfs:label "automated readability index"@en,
        rdfs:label "índice de lecturabilidad automatizado"@es,
        rdfs:label "自动可读性指数"@zh,
        skos:altLabel "ARI"@en,
        skos:definition "The automated readability index is a readability metric designed to estimate the U.S. grade level required to understand a text. It calculates readability using two variables: the average number of characters per word and the average number of words per sentence, with longer words and sentences indicating greater complexity. It produces a numerical score corresponding to an educational grade level, providing a quick, automated measure of text comprehensibility without relying on syllable counts.

ARI = 4.71 (characters / words) + 0.5 (words / sentences) - 21.43"@en
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04057
    
    
Class: roadmap:ROADMAP_04017

    Annotations: 
        dc:source <https://aclanthology.org/W05-0909.pdf>,
        rdfs:label "METEOR"@en,
        rdfs:label "METEOR"@es,
        rdfs:label "显式排序机器翻译评价指标"@zh,
        rdfs:seeAlso <https://en.wikipedia.org/wiki/METEOR>,
        skos:altLabel "METEOR 指标"@zh,
        skos:altLabel "Metric for Evaluation of Translation with Explicit ORdering"@en,
        skos:altLabel "metric for evaluation of translation with explicit ordering score"@en,
        skos:definition "METEOR is an automatic evaluation metric for machine translation that scores a candidate translation against one or more reference translations based on unigram matches. It combines precision and recall in a recall-weighted harmonic mean, applies a penalty for fragmented word order, and supports multiple matching strategies including exact matches, stemming, and synonymy. The metric is designed to improve correlation with human judgments by directly incorporating recall, accounting for linguistic variation, and providing meaningful scores at both sentence and corpus levels."@en,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04059
    
    
Class: roadmap:ROADMAP_04018

    Annotations: 
        dc:source <https://doi.org/10.1121/1.2016299>,
        rdfs:label "perplejidad"@es,
        rdfs:label "perplexity"@en,
        rdfs:label "困惑度"@zh,
        skos:definition "Perplexity quantifies the level of uncertainty or effective choice in predicting sequences, such as words or phonemes in speech or text. It is defined as the exponential of entropy, meaning it represents the average number of equally likely alternatives the model faces at each prediction step. Lower perplexity values indicate that a model assigns higher probability to the observed data, reflecting stronger predictive performance, while higher values signal greater uncertainty and weaker alignment with the actual sequence."@en,
        roadmap:ROADMAP_03651 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04059,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04061
    
    
Class: roadmap:ROADMAP_04019

    Annotations: 
        dc:source <https://doi.org/10.1186/s12859-015-0564-6>,
        rdfs:label "precisión estricta"@es,
        rdfs:label "strict accuracy"@en,
        rdfs:label "严格准确性"@zh,
        skos:altLabel "SACC"@en,
        skos:definition "Strict accuracy is an evaluation metric that measures the proportion of questions or instances answered exactly correctly according to a reference standard. In question answering, it requires that the system’s top response matches the expected answer precisely, without credit for synonyms, partial matches, or alternate valid forms. It is most often applied to binary or factoid-style tasks, where correctness is defined in absolute terms."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03307,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04058,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04059
    
    
Class: roadmap:ROADMAP_04020

    Annotations: 
        dc:source <https://doi.org/10.1007/978-3-642-41230-1_36>,
        rdfs:label "precisión entre los 5 mejores"@es,
        rdfs:label "top-5 accuracy"@en,
        rdfs:label "前 5 名准确率"@zh,
        skos:definition "Top-5 accuracy measures the proportion of instances where the true class label appears within the top 5 predicted class labels, regardless of their order."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03526
    
    
Class: roadmap:ROADMAP_04021

    Annotations: 
        dc:source <https://doi.org/10.1186/s12859-015-0564-6>,
        dc:source <https://doi.org/10.48550/arXiv.2203.07544>,
        rdfs:label "mean reciprocal rank"@en,
        rdfs:label "rango recíproco medio"@es,
        rdfs:label "平均倒数排名"@zh,
        skos:altLabel "MRR"@en,
        skos:definition "Mean reciprocal rank is a metric used to evaluate the effectiveness of systems that return ranked lists of results. For each query, it considers the position of the first relevant item in the ranked list and computes its reciprocal rank, assigning higher scores when the correct result appears earlier. The final score is the mean of these reciprocal ranks across all queries, making the measure particularly suited for tasks where identifying the earliest relevant answer is most important. It emphasizes early precision but accounts only for the first relevant item rather than all relevant results."@en,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_00160,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04061
    
    
Class: roadmap:ROADMAP_04022

    Annotations: 
        dc:source <https://doi.org/10.1007/s10489-021-02635-5>,
        rdfs:label "micro-exhaustividad"@es,
        rdfs:label "micro-recall"@en,
        rdfs:label "微平均召回率"@zh,
        skos:altLabel "global recall"@en,
        skos:altLabel "miR"@en,
        skos:altLabel "micro average recall"@en,
        skos:altLabel "micro recall"@en,
        skos:altLabel "micro-average recall"@en,
        skos:altLabel "sample-averaged recall"@en,
        skos:definition "Micro-recall is the recall value computed by aggregating the true positives and false negatives across all classes before calculating the proportion. It represents the fraction of correctly identified positive instances out of all actual positives in the dataset. Because it gives equal weight to each individual instance, micro-recall reflects overall system performance but can be influenced by majority classes in imbalanced data."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03339,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04054
    
    
Class: roadmap:ROADMAP_04023

    Annotations: 
        dc:source <https://doi.org/10.1007/s10489-021-02635-5>,
        rdfs:label "macro-exhaustividad"@es,
        rdfs:label "macro-recall"@en,
        rdfs:label "宏观召回率"@zh,
        skos:altLabel "balanced recall"@en,
        skos:altLabel "maR"@en,
        skos:altLabel "macro averaged recall"@en,
        skos:altLabel "macro recall"@en,
        skos:altLabel "macro-averaged recall"@en,
        skos:altLabel "unweighted average recall"@en,
        skos:definition "Macro-recall is the unweighted average of recall values calculated separately for each class in a multiclass classification problem. Each class contributes equally to the final score, regardless of how many instances it contains. This metric provides a balanced view of performance across all classes, making it especially useful when evaluating classifiers on imbalanced datasets."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03339,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04055
    
    
Class: roadmap:ROADMAP_04024

    Annotations: 
        dc:source <https://doi.org/10.1007/s10489-021-02635-5>,
        rdfs:label "micro-precision"@en,
        rdfs:label "micro-precisión"@es,
        rdfs:label "微平均精确率"@zh,
        skos:altLabel "miP"@en,
        skos:altLabel "micro precision"@en,
        skos:altLabel "micro-averaged precision"@en,
        skos:definition "Micro-precision is a measure of predictive accuracy in multi-class classification that aggregates the counts of true positives and false positives across all classes before calculating precision. It gives equal weight to every individual instance, making the score dominated by performance on majority classes in imbalanced datasets."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03324,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04054
    
    
Class: roadmap:ROADMAP_04025

    Annotations: 
        dc:source <https://doi.org/10.1007/s10489-021-02635-5>,
        rdfs:label "macro-precision"@en,
        rdfs:label "macro-precisión"@es,
        rdfs:label "宏观精确率"@zh,
        skos:altLabel "maP"@en,
        skos:altLabel "macro precision"@en,
        skos:altLabel "macro-averaged precision"@en,
        skos:definition "Macro-precision is the unweighted average of the precision scores computed separately for each class in a multi-class setting. By treating all classes equally regardless of size, it emphasizes performance across minority classes and provides a balanced view of predictive accuracy in the presence of class imbalance."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03324,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04055
    
    
Class: roadmap:ROADMAP_04026

    Annotations: 
        dc:source <https://doi.org/10.1007/s10489-021-02635-5>,
        dc:source <https://doi.org/10.48550/arXiv.1911.03347>,
        rdfs:label "macro-F1"@en,
        rdfs:label "macro-F1"@es,
        rdfs:label "宏观 F1"@zh,
        skos:altLabel "macro F1"@en,
        skos:altLabel "macro F1 score"@en,
        skos:altLabel "macro-F1 score"@en,
        skos:definition "The macro-F1 score is the unweighted mean of the F1 scores computed separately for each class in a classification task, giving all classes equal influence regardless of their frequency. It can be reported in two distinct ways: (1) as the arithmetic mean of the per-class F1 scores, or (2) as the harmonic mean of the average per-class precision and average per-class recall (“F1 of averages”), with the latter generally producing higher values when class-specific precision and recall differ. Macro-F1 is particularly useful for evaluating performance on imbalanced datasets, as it emphasizes minority-class performance."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03319,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04055
    
    
Class: roadmap:ROADMAP_04027

    Annotations: 
        dc:source <https://doi.org/10.1007/s10489-021-02635-5>,
        rdfs:label "micro-F1"@en,
        rdfs:label "micro-F1"@es,
        rdfs:label "微平均F1分数"@zh,
        skos:altLabel "micro F1"@en,
        skos:altLabel "micro F1 score"@en,
        skos:altLabel "micro-F1 score"@en,
        skos:definition "The micro-F1 score is calculated by aggregating the total true positives, false positives, and false negatives across all classes before computing a single F1 score from these global counts. This approach weights each sample equally, meaning that in multi-class classification it is numerically equivalent to overall accuracy. Micro-F1 favors performance on classes with more samples and is best suited for scenarios where each instance is considered equally important regardless of its class."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03319,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04054
    
    
Class: roadmap:ROADMAP_04028

    Annotations: 
        dc:source <https://doi.org/10.3115/1073445.1073465>,
        rdfs:label "ROUGE-3"@en,
        rdfs:label "ROUGE-3"@es,
        rdfs:label "ROUGE-3"@zh,
        skos:altLabel "Recall-Oriented Understudy for Gisting Evaluation – Trigram Co-Occurrence Statistics"@en,
        skos:definition "ROUGE-3 evaluates the similarity between a generated text and a reference text based on the overlap of trigrams. It uses matching three-word sequences to assess content alignment while incorporating a greater degree of word order sensitivity than lower-order n-grams."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_04006
    
    
Class: roadmap:ROADMAP_04032

    Annotations: 
        dc:source <https://doi.org/10.48550/arXiv.1506.05439>,
        dc:source <https://doi.org/10.48550/arXiv.1701.07875>,
        rdfs:label "Wasserstein loss"@en,
        rdfs:label "Wasserstein 损失"@zh,
        rdfs:label "pérdida de Wasserstein"@es,
        skos:definition "Wasserstein loss is a distributional loss function derived from the theory of optimal transport, which measures the minimal “cost” of transforming one probability distribution into another given a ground distance between their elements. Unlike standard divergences such as cross-entropy, it incorporates semantic relationships between labels, penalizing errors proportionally to their distance in the label space. Through entropic regularization and efficient approximations, it can be optimized in large-scale learning tasks, making it useful for applications such as structured prediction, segmentation, and generative modeling where preserving semantic similarity is important."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04059
    
    
Class: roadmap:ROADMAP_04033

    Annotations: 
        dc:source <https://doi.org/10.1023/A:1026543900054>,
        rdfs:label "distancia de movimiento de tierra"@es,
        rdfs:label "earth mover's distance"@en,
        rdfs:label "推土机距离"@zh,
        skos:altLabel "EMD"@en,
        skos:altLabel "earth mover distance"@en,
        skos:altLabel "earth-mover distance"@en,
        skos:altLabel "earth-mover's distance"@en,
        skos:definition "The earth mover’s distance is a measure of dissimilarity between two distributions that represents the minimum effort required to transform one distribution into the other. It is defined as the optimal total “cost” of moving distribution mass, where cost is determined by the amount of mass moved multiplied by the distance it is transported. Formally expressed as a transportation problem in linear programming, it yields a normalized value that captures how far apart two distributions are in terms of both magnitude and spatial arrangement."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04058
    
    
Class: roadmap:ROADMAP_04034

    Annotations: 
        dc:source <https://doi.org/10.1145/375360.375365>,
        rdfs:label "distancia de edición"@es,
        rdfs:label "edit distance"@en,
        rdfs:label "编辑距离"@zh,
        skos:definition "The edit distance is a general measure of dissimilarity between two strings, defined as the minimum number of character-level operations required to transform one string into the other. Depending on the variant, the allowed operations include insertion, deletion, substitution, and sometimes adjacent transposition. Distances are symmetric and bounded according to the chosen operation set."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04059
    
    
Class: roadmap:ROADMAP_04035

    Annotations: 
        dc:source <https://doi.org/10.1145/375360.375365>,
        rdfs:label "Levenshtein distance"@en,
        rdfs:label "distancia de Levenshtein"@es,
        rdfs:label "莱文斯坦距离"@zh,
        skos:definition "The Levenshtein distance is a classical edit distance that allows insertion, deletion, and substitution operations, each with unit cost. It is defined as the minimum number of such edits required to transform one string into another and is symmetric with values ranging from zero up to the length of the longer string."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_04034
    
    
Class: roadmap:ROADMAP_04036

    Annotations: 
        dc:source <https://doi.org/10.1109/IRI62200.2024.00065>,
        dc:source <https://doi.org/10.48550/arXiv.1703.06856>,
        rdfs:label "counterfactual fairness"@en,
        rdfs:label "equidad contrafactual"@es,
        rdfs:label "反事实公平性"@zh,
        skos:definition "Counterfactual fairness is a causal definition of fairness that requires a predictive model to give the same output for an individual in both the actual world and in a counterfactual world where the individual’s protected attribute (such as race or gender) had been different. Formally, a predictor is counterfactually fair if its distribution of outputs remains unchanged when only the sensitive attribute is altered while all other characteristics are held constant. This criterion ensures that model predictions are not causally influenced by protected attributes, providing an individual-level measure of fairness grounded in causal inference."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04064
    
    
Class: roadmap:ROADMAP_04037

    Annotations: 
        rdfs:label "cross-entropy"@en,
        rdfs:label "entropía cruzada"@es,
        rdfs:label "交叉熵"@zh,
        rdfs:seeAlso "negative log likelihood"@en,
        skos:altLabel "cross entropy"@en,
        skos:definition "Cross-entropy is a generalization of log loss to multi-class classification problems; it quantifies the difference between two probability distributions."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04056
    
    
Class: roadmap:ROADMAP_04038

    Annotations: 
        dc:source <https://doi.org/10.1145/375360.375365>,
        rdfs:label "longest common subsequence"@en,
        rdfs:label "subsecuencia común más larga"@es,
        rdfs:label "最长公共子序列"@zh,
        skos:altLabel "LCS"@en,
        skos:definition "The longest common subsequence distance measures dissimilarity by counting the number of insertions and deletions required to transform one string into another. It is based on the longest sequence of characters appearing in the same order in both strings and ranges from zero to the sum of the string lengths."@en
    
    SubClassOf: 
        roadmap:ROADMAP_04034
    
    
Class: roadmap:ROADMAP_04039

    Annotations: 
        dc:source <https://doi.org/10.1002/j.1538-7305.1950.tb00463.x>,
        dc:source <https://doi.org/10.1145/375360.375365>,
        rdfs:label "Hamming distance"@en,
        rdfs:label "distancia Hamming"@es,
        rdfs:label "汉明距离"@zh,
        skos:definition "The Hamming distance is defined for two strings of equal length and counts the number of positions at which the corresponding characters differ. It is a metric commonly used in coding theory to measure error detection and correction capability, with values ranging from zero to the string length."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_04034
    
    
Class: roadmap:ROADMAP_04040

    Annotations: 
        dc:source <https://doi.org/10.1145/363958.363994>,
        dc:source <https://doi.org/10.1145/375360.375365>,
        rdfs:label "Damerau–Levenshtein distance"@en,
        rdfs:label "Damerau–Levenshtein 距离"@zh,
        rdfs:label "distancia Damerau–Levenshtein"@es,
        skos:altLabel "distancia de Damerau-Levenshtein"@es,
        skos:definition "The Damerau–Levenshtein distance extends the standard edit distance by including adjacent transposition as a primitive operation, in addition to insertion, deletion, and substitution. It reflects the minimum number of these edits needed to transform one string into another, making it particularly suitable for modeling common human typing errors."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_04034
    
    
Class: roadmap:ROADMAP_04041

    Annotations: 
        dc:source <https://doi.org/10.1080/01621459.1989.10478785>,
        rdfs:label "Jaro distance"@en,
        rdfs:label "Jaro距离"@zh,
        rdfs:label "distancia Jaro"@es,
        skos:definition "The Jaro distance is a similarity measure designed for record linkage that accounts for insertions, deletions, replacements, and transpositions of characters. It assigns a prorated weight based on the degree of character agreement between two strings, with higher values indicating greater similarity; its normalized form is widely used for matching names and short text fields."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_04034
    
    
Class: roadmap:ROADMAP_04042

    Annotations: 
        dc:source <https://doi.org/10.1001/jama.1982.03320430047030>,
        dc:source <https://doi.org/10.1177/0962280216680245>,
        rdfs:label "Harrell C 指数"@zh,
        rdfs:label "Harrell’s C-index"@en,
        rdfs:label "índice C de Harrell"@es,
        skos:altLabel "Harrell C index"@en,
        skos:altLabel "Harrell C-index"@en,
        skos:altLabel "Harrell’s C index"@en,
        skos:definition "Harrell’s C-index extends the C-index to censored survival data by evaluating only comparable subject pairs—those in which the shorter observed time corresponds to an actual event. It is calculated as the proportion of such usable pairs where the subject with the earlier event had been assigned a higher predicted risk. Because it excludes incomparable pairs, the statistic depends on the censoring distribution and may not consistently estimate the underlying concordance probability."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03572
    
    
Class: roadmap:ROADMAP_04043

    Annotations: 
        rdfs:label "criterio de rendimiento"@es,
        rdfs:label "performance criterion"@en,
        rdfs:label "性能标准"@zh,
        skos:altLabel "metric type"@en,
        skos:altLabel "objective function"@en,
        skos:definition "The characteristic, such as classification or image segmentation, on which an AI model's performance is evaluated."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00001
    
    
Class: roadmap:ROADMAP_04045

    Annotations: 
        dc:source <https://doi.org/10.1002/sim.4154>,
        dc:source <https://doi.org/10.3348/kjr.2021.0223>,
        rdfs:label "Uno C 指数"@zh,
        rdfs:label "Uno's C-index"@en,
        rdfs:label "índice C de Uno"@es,
        skos:altLabel "Uno C index"@en,
        skos:altLabel "Uno C-index"@en,
        skos:altLabel "Uno's C index"@en,
        skos:definition "Uno’s C-index is a censoring-adjusted version designed to provide a consistent estimate of the concordance probability up to a prespecified time horizon. It uses inverse probability of censoring weighting to include all pairs and correct for censoring, rather than discarding information. This formulation yields a robust, nonparametric measure of survival model discrimination that remains valid under a variety of censoring schemes and model specifications."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03572
    
    
Class: roadmap:ROADMAP_04046

    Annotations: 
        dc:source <https://doi.org/10.1177/0962280216680245>,
        dc:source <https://doi.org/10.3348/kjr.2021.0223>,
        rdfs:label "Efron's C-index"@en,
        rdfs:label "índice C de Efron"@es,
        rdfs:label "埃弗龙 C 指数"@zh,
        skos:altLabel "Efron C index"@en,
        skos:altLabel "Efron C-index"@en,
        skos:altLabel "Efron's C index"@en,
        skos:definition "Efron’s C-index estimates the probability that a subject from one group survives longer than a subject from another group in the presence of censoring. It is computed using Kaplan–Meier survival curves and targets the group-level concordance probability directly, though the original estimator can be biased under administrative censoring. A modified version provides stable, time-truncated estimates and is often reported across follow-up horizons for fair group comparisons."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03572
    
    
Class: roadmap:ROADMAP_04047

    Annotations: 
        dc:source <https://doi.org/10.48550/arXiv.2405.17878>,
        rdfs:label "information difference index"@en,
        rdfs:label "índice de diferencia de información"@es,
        rdfs:label "信息差异指数"@zh,
        skos:altLabel "IDI"@en,
        skos:definition "The information difference index is an information-theoretic metric designed to evaluate the effectiveness of machine unlearning. It quantifies the amount of residual information about the data to be forgotten that remains in a model’s intermediate representations, by comparing mutual information between those features and the forget labels against a reference retrained model. The index is normalized such that values near one indicate no unlearning, values near zero indicate effective unlearning comparable to retraining, and negative values indicate over-unlearning, making it a robust white-box measure that complements output-based black-box metrics."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 -1.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04056
    
    
Class: roadmap:ROADMAP_04048

    Annotations: 
        dc:source <https://doi.org/10.1007/s11547-024-01886-9>,
        dc:source <https://doi.org/10.1093/rpd/ncp305>,
        dc:source <https://doi.org/10.1118/1.596358>,
        rdfs:label "area under the alternative free-response operating characteristic curve"@en,
        rdfs:label "área bajo la curva característica de funcionamiento de respuesta libre alternativa"@es,
        rdfs:label "替代自由响应工作特征曲线下的面积"@zh,
        skos:altLabel "AUAFROC"@en,
        skos:altLabel "AUC_AFROC"@en,
        skos:altLabel "area under AFROC curve"@en,
        skos:altLabel "area under the AFROC curve"@en,
        skos:definition "The area under the alternative free-response operating characteristic curve is a figure of merit used to quantify observer performance in free-response diagnostic imaging studies. It is derived from the alternative free-response operating characteristic curve, which plots the lesion localization fraction against the false-positive fraction, providing a bounded, case-based representation of detection and localization accuracy. It reflects the probability that a correctly localized lesion receives a higher confidence rating than a false-positive mark, and serves as a single, standardized summary measure of localization-based diagnostic accuracy."@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04058
    
    
Class: roadmap:ROADMAP_04049

    Annotations: 
        dc:source <https://doi.org/10.1111/lnc3.12196>,
        rdfs:label "sorpresa"@es,
        rdfs:label "surprisal"@en,
        rdfs:label "意外性"@zh,
        skos:definition "Surprisal is a measure of the unexpectedness of an event, defined as the logarithm of the reciprocal of its probability. In language processing, it represents the difficulty of comprehending a word given its preceding context, with less probable words yielding higher surprisal values. Surprisal predicts that more unexpected words impose greater processing effort, and has been widely linked to behavioral and neural measures of comprehension difficulty."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04056
    
    
Class: roadmap:ROADMAP_04050

    Annotations: 
        dc:source <https://doi.org/10.1111/lnc3.12196>,
        rdfs:label "entropy reduction"@en,
        rdfs:label "reducción de entropía"@es,
        rdfs:label "熵减"@zh,
        skos:definition "Entropy reduction is an information-theoretic metric that quantifies processing difficulty as the decrease in uncertainty about possible interpretations when new input is encountered. It is defined as the difference between the entropy of possible derivations before and after observing a word or structure, reflecting how much ambiguity has been resolved. Larger reductions correspond to greater computational work by the parser, while increases in entropy indicate that uncertainty has not been reduced."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04056
    
    
Class: roadmap:ROADMAP_04051

    Annotations: 
        dc:source <https://doi.org/10.1002/j.1538-7305.1948.tb01338.x>,
        rdfs:label "conditional entropy"@en,
        rdfs:label "entropía condicional"@es,
        rdfs:label "条件熵"@zh,
        skos:definition "Conditional entropy quantifies the remaining uncertainty about one random variable when the value of another related variable is known. It represents the expected amount of information needed to describe the outcome of a variable given prior knowledge of another. Conditional entropy is always less than or equal to the entropy of the variable alone, with equality occurring when the variables are independent."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03556
    
    
Class: roadmap:ROADMAP_04052

    Annotations: 
        dc:source <https://www.jstor.org/stable/2236703>,
        rdfs:label "KL散度(即相对熵) or“库尔贝克 - 莱布勒散度”"@zh,
        rdfs:label "Kullback-Leibler divergence"@en,
        rdfs:label "divergencia de Kullback-Leibler"@es,
        skos:altLabel "KL"@en,
        skos:altLabel "KLD"@en,
        skos:altLabel "relative entropy"@en,
        skos:definition "Kullback–Leibler divergence is a measure of how one probability distribution differs from a second, reference distribution. It is defined as the expected logarithmic ratio of the probabilities under the two distributions, with the expectation taken over the first distribution. The divergence is non-negative, equals zero only when the two distributions are identical almost everywhere, and is generally asymmetric, meaning the divergence from P to Q is not the same as from Q to P."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04056
    
    
Class: roadmap:ROADMAP_04053

    Annotations: 
        dc:source <https://doi.org/10.1109/TIT.2004.838101>,
        rdfs:label "distancia de información normalizada"@es,
        rdfs:label "normalized information distance"@en,
        rdfs:label "归一化信息距离"@zh,
        skos:altLabel "NID"@en,
        skos:definition "Normalized information distance is a theoretical measure of similarity between two objects based on Kolmogorov complexity. It quantifies the maximum amount of information required to transform one object into the other, normalized by the larger of their individual complexities, resulting in a value between zero and one. This measure is universal in that it captures all effective similarities, but it is not computable in practice due to the incomputability of Kolmogorov complexity."@en,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04056
    
    
Class: roadmap:ROADMAP_04054

    Annotations: 
        rdfs:comment "If the dataset is imbalanced (some classes have significantly more instances than others), a micro-averaged metric can be misleading if the model performs poorly on minority classes but well on the majority class."@en,
        rdfs:label "micro-averaged classification performance"@en,
        rdfs:label "rendimiento de clasificación micro-promediada"@es,
        rdfs:label "微平均分类"@zh,
        skos:altLabel "clasificación micro-promediada"@es,
        skos:altLabel "micro average metric"@en,
        skos:altLabel "micro-average metric"@en,
        skos:altLabel "micro-averaged classification"@en,
        skos:altLabel "micro-averaged classification metric"@en,
        skos:altLabel "微平均分类指标"@zh,
        skos:definition "A micro-averaged metric is one that aggregates data from all classes before calculation; thus, the metric is the aggregate across all classes."@en
    
    SubClassOf: 
        roadmap:ROADMAP_04058
    
    
Class: roadmap:ROADMAP_04055

    Annotations: 
        rdfs:comment "A macro-averaged metric gives equal weight to each class, so it can be more sensitive to a model's performance on minority classes in imbalanced datasets."@en,
        rdfs:label "macro-averaged classification performance"@en,
        rdfs:label "rendimiento de clasificación macro-promediada"@es,
        rdfs:label "宏观平均分类"@zh,
        skos:altLabel "clasificación macro-promediada"@es,
        skos:altLabel "macro average metric"@en,
        skos:altLabel "macro-average metric"@en,
        skos:altLabel "macro-averaged classification"@en,
        skos:altLabel "macro-averaged classification metric"@en,
        skos:altLabel "宏平均分类指标"@zh,
        skos:definition "A macro-averaged metric, such as precision or recall, is the unweighted average of the metric score calculated for each class independently."@en
    
    SubClassOf: 
        roadmap:ROADMAP_04058
    
    
Class: roadmap:ROADMAP_04056

    Annotations: 
        rdfs:label "contenido de información"@es,
        rdfs:label "information content"@en,
        rdfs:label "信息内容"@zh,
        skos:altLabel "information-theoretic metric"@en,
        skos:definition "A metric, such as entropy, derived from information theory."@en
    
    SubClassOf: 
        roadmap:ROADMAP_04043
    
    
