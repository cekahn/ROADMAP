        skos:altLabel "known failure mode"@en,
        skos:altLabel "known failure modes"@en,
        skos:definition "Known circumstances where the device input will not align with the data used in development and validation."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03621
    
    
Class: roadmap:ROADMAP_03630

    Annotations: 
        dc:source "https://www.fda.gov/media/184856/download"@en,
        rdfs:label "brecha conocida en la caracterización de los datos"@es,
        rdfs:label "known data-characterization gap"@en,
        rdfs:label "已知数据特征描述差距"@zh,
        skos:definition "Known gaps in the data characterization, such as patient populations that are not well represented in development (e.g., training) or testing datasets, and therefore, may be at risk of bias."@en
    
    SubClassOf: 
        roadmap:ROADMAP_03621
    
    
Class: roadmap:ROADMAP_03631

