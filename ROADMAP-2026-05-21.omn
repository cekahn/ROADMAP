    Annotations: 
        rdfs:label "adjusted Rand index"@en,
        rdfs:label "adjusted Rand index"@zh,
        rdfs:label "Índice de Rand ajustado"@es,
        skos:altLabel "ARI"@en,
        skos:definition "The Adjusted Rand Index (ARI) is a cluster validation metric measuring similarity between two data clusterings by evaluating all pair-wise sample assignments, corrected for chance. Ranging from -1 to 1, an ARI of 1 indicates perfect agreement, 0 represents random labeling, and negative values indicate worse-than-random performance"@en,
        roadmap:ROADMAP_03651 -1.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03545,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_00145
    
    
