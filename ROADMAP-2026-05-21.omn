        skos:altLabel "computer-assisted detection/diagnosis"@en,
        skos:altLabel "diagnosis / detection"@en,
        skos:definition "Use of an AI system to detect and/or diagnose one or more conditions."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00015
    
    
