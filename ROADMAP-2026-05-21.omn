        rdfs:label "多模态一致性"@zh,
        skos:altLabel "MMC"@en,
        skos:altLabel "multi-modal concordance index"@en,
        skos:definition "Multi-modal concordance (MMC) aggregates metrics from various sources to assess overall data drift without assuming access to reference-standard \"truth\" labels needed to monitor model performance."@en
    
