    Annotations: 
        dc:rights <https://creativecommons.org/licenses/by/4.0/>,
        dc:source <https://doi.org/10.1038/sdata.2016.18>,
        rdfs:comment "FAIR principles are incorporated under the Creative Commons CC BY 4.0 license."@en,
        rdfs:label "FAIR principle"@en,
        rdfs:seeAlso <https://www.go-fair.org/fair-principles/>,
        skos:altLabel "FAIR"@en,
        skos:altLabel "FAIR Guiding Principles"@en,
        skos:definition "Principles that stress the findability, accessibility, interoperability, and reusability of scientific data."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00248
    
    
Class: roadmap:ROADMAP_00170

    Annotations: 
        rdfs:label "accessibility"@en,
        skos:altLabel "FAIR-A"@en,
        skos:altLabel "accessibility principle"@en,
        skos:altLabel "accessible"@en,
        skos:definition "Accessible: Once found, users must know how to access the data. This requires clear access protocols (often open and standardized) and ensures that metadata remains accessible even if the underlying data is restricted or deleted."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00169
    
    
Class: roadmap:ROADMAP_00171

    Annotations: 
        rdfs:label "findability"@en,
        skos:altLabel "FAIR-F"@en,
        skos:altLabel "findability principle"@en,
        skos:altLabel "findable"@en,
        skos:definition "Findable: Data and metadata should be easy for both humans and computers to locate. They require globally unique, persistent identifiers (like a DOI) and rich descriptive information."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00169
    
    
Class: roadmap:ROADMAP_00172

    Annotations: 
        rdfs:label "interoperability"@en,
        skos:altLabel "FAIR-I"@en,
        skos:altLabel "interoperability principle"@en,
        skos:altLabel "interoperable"@en,
        skos:definition "Interoperable: Data should be able to integrate and work alongside other data systems. This means using shared, standard languages (like JSON or XML) and formal vocabularies so systems can exchange information seamlessly."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00169
    
    
Class: roadmap:ROADMAP_00173

    Annotations: 
        rdfs:label "reuseability"@en,
        skos:altLabel "FAIR-R"@en,
        skos:altLabel "reuseability principle"@en,
        skos:altLabel "reuseable"@en,
        skos:definition "Reusable: The ultimate goal of FAIR. To optimize data for future use and replication, datasets must include clear usage licenses, detailed provenance (origin history), and adhere to domain-specific community standards."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00169
    
    
Class: roadmap:ROADMAP_00174

    Annotations: 
        rdfs:label "guideline"@en,
        skos:altLabel "AI reporting guideline"@en,
        skos:altLabel "reporting guideline"@en,
        skos:definition "An AI reporting guideline is a structured, consensus-driven framework—typically formatted as a standardized checklist—designed to ensure transparency and reproducibility in scientific research. These guidelines dictate the minimum baseline information authors must disclose."@en
    
    SubClassOf: 
        roadmap:ROADMAP_00001
    
    
Class: roadmap:ROADMAP_00175

