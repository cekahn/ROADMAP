        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04057
    
    
Class: roadmap:ROADMAP_03707

    Annotations: 
        dc:source "https://doi.org/10.1016/j.aci.2018.08.003"@en,
        rdfs:label "marcabilidad"@es,
        rdfs:label "markedness"@en,
        rdfs:label "标记度 "@zh,
        skos:altLabel "MK"@en,
        skos:altLabel "delta P"@en,
        skos:altLabel "delta-P"@en,
        skos:altLabel "deltaP"@en,
        skos:altLabel "Δp"@en,
        skos:definition "Markedness is a metric that quantifies the reliability of predictions by combining positive predictive value and negative predictive value. It is defined as the sum of these two predictive values minus one, producing a score that ranges from –1 to +1. A value of +1 indicates perfectly trustworthy predictions, 0 corresponds to chance-level performance, and negative values indicate systematically misleading predictions; however, the measure is sensitive to class prevalence and can be unstable in imbalanced datasets.

MK = PPV + NPV - 1"@en,
        roadmap:ROADMAP_00274 1.,
        roadmap:ROADMAP_03651 -1.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04058
    
    
Class: roadmap:ROADMAP_03708

    Annotations: 
        dc:source "https://doi.org/10.1016/j.aci.2018.08.003"@en,
        rdfs:label "balanced error rate"@en,
        rdfs:label "tasa de error equilibrada"@es,
        rdfs:label "平衡错误率"@zh,
        skos:altLabel "BER"@en,
        skos:altLabel "HTER"@en,
        skos:altLabel "half total error rate"@en,
        skos:definition "Balanced error rate measures the average of the false positive rate and the false negative rate, giving equal weight to both types of errors. It is conceptually the counterpart of the balanced accuracy (balanced classification rate), emphasizing error rather than correct classification, and is particularly useful for imbalanced datasets where overall accuracy can be misleading. Lower values indicate better performance, with zero representing perfect classification and one representing the worst case."@en,
        roadmap:ROADMAP_00274 0.,
        roadmap:ROADMAP_03651 0.,
        roadmap:ROADMAP_03652 1.
    
    SubClassOf: 
        roadmap:ROADMAP_03302,
        roadmap:ROADMAP_03648 some roadmap:ROADMAP_04058
    
    
Class: roadmap:ROADMAP_03721

