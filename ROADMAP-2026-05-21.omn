        dc:source <https://doi.org/10.1111/j.1469-8137.1912.tb05611.x>,
        rdfs:label "intersección de máscara sobre unión > 0"@es,
        rdfs:label "mask intersection over union > 0"@en,
        rdfs:label "掩码交并比 > 0"@zh,
        skos:altLabel "mask IoU > 0"@en,
        skos:definition "Mask intersection over union > 0 determines whether a predicted region shares at least one pixel with the reference region. It operates as a binary localization criterion, indicating only the presence or absence of spatial overlap. This metric provides an extremely permissive threshold for detection tasks where coarse positional matching is sufficient."@en,
        roadmap:ROADMAP_03651 false,
        roadmap:ROADMAP_03652 true
    
