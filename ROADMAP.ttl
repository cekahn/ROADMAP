###  https://rsna.org/roadmap/ROADMAP_03472
<https://rsna.org/roadmap/ROADMAP_03472> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_00666> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_00130> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_00055>
                                                         ] ;
                                         rdfs:comment """For example, if a Partition has 500 male patients and 600 female patients, one could list two Subsets to indicate those two groups.  One also could indicate a Subset of 1100 patients to cover the entire Partition.

                                         A Subset has one of more Count values (e.g., number of patients, number of images) and one or more Patient descriptors (age, sex, etc.)"""@en ;
                                         rdfs:label "subconjunto"@es ,
                                                    "subset"@en ,
                                                    "子集"@zh ;
                                         skos:definition "A subset is all or part of a dataset or partition: it is used to describe the demographics of the entity of which it's a part."@en .


###  https://rsna.org/roadmap/ROADMAP_03477
<https://rsna.org/roadmap/ROADMAP_03477> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03422> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_00198> ;
                                                           owl:hasValue <https://rsna.org/roadmap/ROADMAP_00212>
                                                         ] ;
                                         rdfs:comment """Criteria (described as text) include:
                                         - Reference standard (\"ground truth\") value
                                         - Imaging finding
                                         - Geographic group
                                         - Image source
                                         - Risk factor"""@en ;
                                         rdfs:label "criterio de subconjunto"@es ,
                                                    "subset criterion"@en ,
                                                    "子集标准"@zh ;
                                         skos:definition "A criterion other than Age, Sex, and Demograpic Group (race / ethnicity) by which to define a dataset, partition, or subset theireof."@en .


###  https://rsna.org/roadmap/ROADMAP_03479
<https://rsna.org/roadmap/ROADMAP_03479> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_00051> ;
