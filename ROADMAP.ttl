                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03342>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03356>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03547>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03707>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_04073>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_04074>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_04080>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_04081>
                                                         ] ;
                                         rdfs:label "confusion matrix"@en ,
                                                    "matriz de confusión"@es ,
                                                    "混淆矩阵"@zh ;
                                         rdfs:seeAlso <https://en.wikipedia.org/wiki/Confusion_matrix> ,
                                                      <https://es.wikipedia.org/wiki/Matriz_de_confusi%C3%B3n> ;
                                         skos:altLabel "error table"@en ,
                                                       "matriz de errores"@es ,
                                                       "table of confusion"@en ;
                                         skos:definition "A matrix that displays observed vs. predicted classes. Each row in a confusion matrix represents a true (observed) class and each column represents a predicted class. The value of each cell of the matrix is the number of instances of that combination of observed and predicted classes."@en .


###  https://rsna.org/roadmap/ROADMAP_03549
<https://rsna.org/roadmap/ROADMAP_03549> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1016/j.neucom.2015.12.114> ;
                                         rdfs:label "error porcentual absoluto medio"@es ,
                                                    "mean absolute percentage error"@en ,
                                                    "平均绝对百分比误差"@zh ;
                                         skos:altLabel "MAPE"@en ;
                                         skos:definition "Mean absolute percentage error is a regression accuracy measure that quantifies prediction error as a relative percentage. It is defined as the average of the absolute differences between predicted and true values, divided by the corresponding true values. This formulation makes the metric scale-independent but can become unstable when actual values are close to zero."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. .


###  https://rsna.org/roadmap/ROADMAP_03550
<https://rsna.org/roadmap/ROADMAP_03550> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap#ROADMAP_03649> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1016/j.ijforecast.2006.03.001> ;
                                         rdfs:label "error escalado absoluto medio"@es ,
                                                    "mean absolute scaled error"@en ,
                                                    "平均绝对标度误差"@zh ;
                                         skos:altLabel "MASE"@en ;
                                         skos:definition "Mean absolute scaled error is a scale-independent measure of forecast accuracy that compares the mean absolute error of a model to that of a naïve baseline forecast. It is calculated by dividing the average absolute prediction error by the average absolute error from a one-step naïve forecast, with seasonal variants using a seasonal naïve baseline. A value equal to one indicates performance equivalent to the naïve method, values below one reflect improvement, and values above one indicate worse performance, making the metric interpretable, symmetric, and robust across datasets with different scales or containing zeros."@en .


###  https://rsna.org/roadmap/ROADMAP_03551
<https://rsna.org/roadmap/ROADMAP_03551> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03654> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.48550/arXiv.2102.01454> ;
                                         rdfs:label "MAUVE"@en ,
                                                    "MAUVE"@es ,
                                                    "人机文本分布散度曲线评估指标"@zh ;
                                         skos:altLabel "Measure Aggregated from Unsupervised Evaluation"@en ;
                                         skos:definition "MAUVE measures the similarity between the distribution of machine-generated text and human-written text in open-ended generation tasks. It computes this similarity by embedding both text sets in a contextual space, quantizing them, and comparing their distributions using divergence-based methods. The score reflects how well the generated text aligns with human text in terms of both quality and diversity, with higher values indicating closer distributional alignment."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03552
<https://rsna.org/roadmap/ROADMAP_03552> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03342> ;
                                         dc:source <https://doi.org/10.1038/s41592-023-02151-z> ,
                                                   <https://doi.org/10.1111/j.1469-8137.1912.tb05611.x> ;
                                         rdfs:label "intersección sobre unión media"@es ,
                                                    "mean intersection over union"@en ,
                                                    "平均交并比"@zh ;
                                         skos:altLabel "mean IoU"@en ,
                                                       "mean intersection over union"@en ;
                                         skos:definition "Mean intersection over union aggregates intersection-over-union values computed across multiple classes or instances into a single average score. It provides a balanced assessment of segmentation performance by accounting for all evaluated categories equally or with specified weights. This metric is standard in multi-class segmentation tasks to summarize overall prediction quality across diverse structures."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03553
<https://rsna.org/roadmap/ROADMAP_03553> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03652> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1080/00031305.1988.10475524> ,
                                                   <https://doi.org/10.1098/rspl.1895.0041> ;
                                         rdfs:label "Pearson correlation coefficient"@en ,
                                                    "coeficiente de correlación de Pearson"@es ,
                                                    "皮尔逊相关系数"@zh ;
                                         skos:altLabel "Pearson r coefficient"@en ,
                                                       "Pearson's correlation coefficient"@en ,
                                                       "R"@en ,
                                                       "r"@en ;
                                         skos:definition "The Pearson correlation coefficient is a dimensionless statistic that quantifies the strength and direction of a linear relationship between two continuous variables. It is computed by standardizing the covariance of the variables, producing a value between –1 and +1, where the sign indicates the direction of association and the magnitude reflects its strength. Statistical inference for this coefficient commonly assumes that the paired variables are jointly normally distributed, particularly when deriving p-values or confidence intervals."@en ;
                                         skos:exactMatch "http://purl.obolibrary.org/obo/STATO_0000280" ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> -1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03554
<https://rsna.org/roadmap/ROADMAP_03554> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03652> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.7717/peerj-cs.623> ;
                                         rdfs:label "R cuadrado"@es ,
                                                    "R-squared"@en ,
                                                    "R方"@zh ;
                                         skos:altLabel "R squared"@en ,
                                                       "R2"@zh ,
                                                       "R²"@en ,
                                                       "coefficient of determination"@en ,
                                                       "r^2"@en ,
                                                       "r²"@en ;
                                         skos:definition "The coefficient of determination (R^2), is a statistical measure that expresses the proportion of variance in a dependent variable that is explained by the independent variable(s) in a regression model. It is calculated from the squared Pearson correlation between predicted and observed values and commonly ranges from 0 (no variance explained) to 1 (all variance explained), though values below 0 can occur when the model performs worse than a mean-based prediction. R^2 is widely used to assess the goodness of fit in regression analysis, with higher values indicating greater explanatory power."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03555
<https://rsna.org/roadmap/ROADMAP_03555> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03549> ;
                                         dc:source <https://doi.org/10.1016/0169-2070(92)90008-W> ;
                                         rdfs:label "error porcentual absoluto medio simétrico"@es ,
                                                    "symmetric mean absolute percentage error"@en ,
                                                    "对称平均绝对百分比误差"@zh ;
                                         skos:altLabel "sMAPE"@en ;
                                         skos:definition "Symmetric mean absolute percentage error is a modification of mean absolute percentage error that addresses its asymmetry in penalizing over- and under-predictions. It is defined as the average of the absolute differences between predicted and true values, divided by the mean of their absolute values. This metric is bounded between 0% and 200%, ensuring equal treatment of overestimation and underestimation of the same magnitude."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 2. .


###  https://rsna.org/roadmap/ROADMAP_03556
<https://rsna.org/roadmap/ROADMAP_03556> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03647> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1002/j.1538-7305.1948.tb01338.x> ;
                                         rdfs:label "entropy"@en ,
                                                    "entropía"@es ,
                                                    "熵"@zh ;
                                         skos:definition "Entropy is a measure of the average uncertainty or information content associated with a discrete random variable. It quantifies the expected amount of information required to describe the outcome of the variable, based on its probability distribution. Higher entropy corresponds to greater unpredictability in outcomes, while lower entropy reflects more certainty."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. .


###  https://rsna.org/roadmap/ROADMAP_03557
<https://rsna.org/roadmap/ROADMAP_03557> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03653> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1007/s11547-024-01886-9> ,
                                                   <https://doi.org/10.1371/journal.pone.0077089> ;
                                         rdfs:label "relación señal-ruido"@es ,
                                                    "signal-to-noise ratio"@en ,
                                                    "信噪比"@zh ;
                                         skos:altLabel "S-N ratio"@en ,
                                                       "S/N"@en ,
                                                       "S/N ratio"@en ,
                                                       "SNR"@en ,
                                                       "signal to noise ratio"@en ;
                                         skos:definition "Signal-to-noise ratio quantifies the relationship between the strength of a signal and the level of background noise in a measurement or image. It is calculated as the ratio of the mean signal intensity to the standard deviation of the noise, indicating how clearly the signal can be distinguished from noise. Higher signal-to-noise ratio values correspond to better image or data quality."@en ;
                                         skos:exactMatch "http://purl.obolibrary.org/obo/STATO_0000050" ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. .


###  https://rsna.org/roadmap/ROADMAP_03558
<https://rsna.org/roadmap/ROADMAP_03558> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03557> ;
                                         dc:source <https://doi.org/10.1007/s11547-024-01886-9> ,
                                                   <https://doi.org/10.1109/QoMEX.2012.6263880> ;
                                         rdfs:label "peak signal-to-noise ratio"@en ,
                                                    "relación señal-ruido máxima"@es ,
                                                    "峰值信噪比"@zh ;
                                         skos:altLabel "PSNR"@en ,
                                                       "peak SNR"@en ;
                                         skos:definition "Peak signal-to-noise ratio evaluates the fidelity of a reconstructed or compressed image compared to its original version. It is based on the mean squared error between corresponding pixels and expressed as a logarithmic ratio relative to the maximum possible signal value. Higher peak signal-to-noise ratio values generally indicate less distortion and better preservation of the original image quality."@en .


###  https://rsna.org/roadmap/ROADMAP_03559
<https://rsna.org/roadmap/ROADMAP_03559> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03329> ;
                                         dc:source <https://doi.org/10.1198/016214506000001437> ;
                                         rdfs:label "multiclass Brier score"@en ,
                                                    "puntuación Brier multiclase"@es ,
                                                    "多分类 Brier 分数"@zh ;
                                         skos:definition "The multiclass Brier score extends the Brier score to multi-class classification by computing the mean squared difference between the predicted probability distribution over all classes and the true one-hot encoded outcome. It summarizes both calibration and discrimination across all classes into a single value, with lower scores indicating more accurate probabilistic predictions."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 2. .


###  https://rsna.org/roadmap/ROADMAP_03561
<https://rsna.org/roadmap/ROADMAP_03561> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03566> ;
                                         rdfs:label "medical record number"@en ,
                                                    "número de historia clínica"@es ,
                                                    "病历号"@zh ;
                                         skos:altLabel "MRN"@en ;
                                         skos:definition "A Medical Record Number (MRN) is a unique identifier assigned by a healthcare organization to a patient or study participant to manage their clinical records within that specific healthcare system."@en ;
                                         skos:exactMatch <http://purl.bioontology.org/ontology/SNOMEDCT/398225001> ,
                                                         <http://www.radlex.org/RID/RID13161> .


###  https://rsna.org/roadmap/ROADMAP_03562
<https://rsna.org/roadmap/ROADMAP_03562> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03561> ;
                                         rdfs:label "actual medical record number"@en ,
                                                    "número real de historia clínica"@es ,
                                                    "实际病历号"@zh ;
                                         skos:altLabel "actual MRN"@en ;
                                         skos:definition "The actual (not de-identified) identifier of a patient or study participant."@en .


###  https://rsna.org/roadmap/ROADMAP_03563
<https://rsna.org/roadmap/ROADMAP_03563> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03561> ;
                                         rdfs:label "número seudonimizado de historia clínica"@es ,
                                                    "pseudonymized medical record number"@en ,
                                                    "匿名化病历号"@zh ;
                                         skos:altLabel "pseudo MRN"@en ;
                                         skos:definition "A pseudonymized medical record number (MRN) is an artificial identifier—such as a token, scrambled code, or random number—that replaces a patient's actual MRN to protect privacy. It allows researchers to link, track, and analyze longitudinal data for the same patient across different systems without accessing direct identifiers,"@en .


###  https://rsna.org/roadmap/ROADMAP_03564
<https://rsna.org/roadmap/ROADMAP_03564> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03422> ;
                                         rdfs:label "determinante social de la salud"@es ,
                                                    "social determinant of health"@en ,
                                                    "健康社会决定因素"@zh ;
                                         rdfs:seeAlso <https://en.wikipedia.org/wiki/Social_determinants_of_health> ,
                                                      "https://odphp.health.gov/healthypeople/priority-areas/social-determinants-health"@en ;
                                         skos:altLabel "SDOH"@en ;
                                         skos:definition "A non-medical factor that influences health outcomes, including social conditions in which people are born, live, learn, work, play, worship, and age."@en .


###  https://rsna.org/roadmap/ROADMAP_03565
<https://rsna.org/roadmap/ROADMAP_03565> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03422> ;
                                         rdfs:label "demographic descriptor"@en ,
                                                    "descriptor demográfico"@es ,
                                                    "人口统计学描述符"@zh ;
                                         skos:definition "A patient descriptor, such as age, sex, and race / ethnicity"@en .


###  https://rsna.org/roadmap/ROADMAP_03566
<https://rsna.org/roadmap/ROADMAP_03566> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03422> ;
                                         rdfs:label "identificador único de paciente"@es ,
                                                    "unique patient identifier"@en ,
                                                    "唯一患者标识符"@zh ;
                                         skos:altLabel "UPI"@en ;
                                         skos:definition "A Unique Patient Identifier (UPI) is a distinct, non-changing alphanumeric code assigned to a single person to accurately link them to their medical information."@en .


###  https://rsna.org/roadmap/ROADMAP_03567
<https://rsna.org/roadmap/ROADMAP_03567> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_00029> ;
                                         rdfs:label "instance segmentation"@en ,
                                                    "segmentación de instancias"@es ,
                                                    "实例分割"@zh ;
                                         skos:definition "Instance segmentation is an approach that identifies, for every pixel, the specific belonging instance of the object. It detects each distinct object of interest in the image."@en .


###  https://rsna.org/roadmap/ROADMAP_03568
<https://rsna.org/roadmap/ROADMAP_03568> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_00029> ;
                                         rdfs:label "segmentación semántica"@es ,
                                                    "semantic segmentation"@en ,
                                                    "语义分割"@zh ;
                                         skos:definition "Semantic segmentation is a computer vision technique that classifies every pixel in an image into a specific category."@en .


###  https://rsna.org/roadmap/ROADMAP_03570
<https://rsna.org/roadmap/ROADMAP_03570> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03638> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03641> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03653>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03654>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03655>
                                                         ] ;
                                         dc:source <https://doi.org/10.1186/s12916-019-1466-7> ;
                                         rdfs:label "calibration curve"@en ,
                                                    "curva de calibración"@es ,
                                                    "校准曲线"@zh ;
                                         rdfs:seeAlso <https://en.wikipedia.org/wiki/Calibration_curve> ;
                                         skos:altLabel "calibration"@en ,
                                                       "calibration analysis"@en ,
                                                       "calibration plot"@en ;
                                         skos:definition "Calibration in statistical modeling refers to the agreement between predicted probabilities and observed outcomes. A well-calibrated model will have predicted probabilities that match the empirical frequencies of events."@en ;
                                         skos:exactMatch "http://purl.obolibrary.org/obo/STATO_0000655" .


###  https://rsna.org/roadmap/ROADMAP_03571
<https://rsna.org/roadmap/ROADMAP_03571> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1117/1.JMI.11.2.024504> ,
                                                   <https://doi.org/10.1177/0962280214537390> ;
                                         rdfs:label "coeficiente de correlación de concordancia"@es ,
                                                    "concordance correlation coefficient"@en ,
                                                    "一致性相关系数"@zh ;
                                         skos:altLabel "CCC"@en ;
                                         skos:definition "The concordance correlation coefficient measures the agreement between two continuous variables by evaluating both their correlation and their deviation from the line of perfect concordance (y = x). It combines precision (strength of linear association) and accuracy (closeness to the 45° line) into a single metric, making it suitable for assessing the closeness of predicted and reference values. Higher values indicate stronger agreement, while lower values reflect greater bias or variability between the two measurements."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> -1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03572
<https://rsna.org/roadmap/ROADMAP_03572> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1186/1471-2288-12-82> ,
                                                   <https://doi.org/10.3348/kjr.2021.0223> ;
                                         rdfs:label "concordance index"@en ,
                                                    "índice de concordancia"@es ,
                                                    "一致性指数"@zh ;
                                         skos:altLabel "C index"@en ,
                                                       "C statistic"@en ,
                                                       "C-index"@en ,
                                                       "concordance statistic"@en ;
                                         skos:definition "The concordance index is a rank-based measure of model discrimination that quantifies the probability that, for a randomly chosen pair of subjects with different outcomes, the subject experiencing the event (or an earlier event time) is assigned a higher predicted risk. For binary outcomes, it is mathematically equivalent to the area under the ROC curve. In survival analysis, it generalizes by comparing risk orderings with observed event times while accounting for censoring."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03573
<https://rsna.org/roadmap/ROADMAP_03573> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1016/0030-5073(82)90237-9> ,
                                                   <https://doi.org/10.1117/1.JMI.11.2.024504> ;
                                         rdfs:label "discrimination slope"@en ,
                                                    "pendiente de discriminación"@es ,
                                                    "判别斜率"@zh ;
                                         skos:definition "Discrimination slope quantifies a model's ability to distinguish between two outcome classes by comparing predicted probabilities. It is calculated as the difference between the mean predicted likelihood for cases with the outcome and the mean predicted likelihood for cases without the outcome. Higher values indicate better separation between outcome categories."@en .


###  https://rsna.org/roadmap/ROADMAP_03574
<https://rsna.org/roadmap/ROADMAP_03574> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1117/1.JMI.11.2.024504> ,
                                                   <https://doi.org/10.1177/0962280214537390> ;
                                         rdfs:label "coeficiente de correlación intraclase"@es ,
                                                    "intraclass correlation coefficient"@en ,
                                                    "组内相关系数"@zh ;
                                         skos:altLabel "ICC"@en ;
                                         skos:definition "Intraclass correlation coefficient evaluates the degree of agreement or consistency between repeated measurements or ratings of the same quantity. It represents the proportion of total variance attributable to differences between subjects rather than measurement error. Higher values denote greater reliability of the estimation process."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03576
<https://rsna.org/roadmap/ROADMAP_03576> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03528> ;
                                         dc:source <https://doi.org/10.1117/1.JMI.11.2.024504> ,
                                                   <https://doi.org/10.1364/oe.16.008150> ;
                                         rdfs:label "ensemble mean square error"@en ,
                                                    "error cuadrático medio del conjunto"@es ,
                                                    "集成均方误差"@zh ;
                                         skos:altLabel "EMSE"@en ;
                                         skos:definition "Ensemble mean-square error is the average of mean-square error values computed across a range of reference parameter values. It summarizes an estimator’s performance over its full operating range rather than at a single reference point. This measure is useful for assessing generalizability and robustness."@en .


###  https://rsna.org/roadmap/ROADMAP_03577
<https://rsna.org/roadmap/ROADMAP_03577> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03649> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1117/1.JMI.11.2.024504> ,
                                                   <https://doi.org/10.1177/0962280214537390> ;
                                         rdfs:label "coeficiente de repetibilidad"@es ,
                                                    "repeatability coefficient"@en ,
                                                    "重复性系数"@zh ;
                                         skos:altLabel "RC"@en ;
                                         skos:definition "Repeatability coefficient represents the smallest difference between two measurements under identical conditions that can be considered statistically significant. It reflects the short-term precision of an estimator when system, operator, and protocol remain constant. Smaller values correspond to greater measurement consistency."@en .


###  https://rsna.org/roadmap/ROADMAP_03578
<https://rsna.org/roadmap/ROADMAP_03578> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03649> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1117/1.JMI.11.2.024504> ,
                                                   <https://doi.org/10.1177/0962280214537390> ;
                                         rdfs:label "coeficiente de reproducibilidad"@es ,
                                                    "reproducibility coefficient"@en ,
                                                    "可重复性系数"@zh ;
                                         skos:altLabel "RDC"@en ;
                                         skos:definition "Reproducibility coefficient represents the smallest difference between two measurements obtained under varying conditions that can be considered statistically significant. It captures the long-term or multi-setting precision of an estimator, accounting for differences in sites, operators, or equipment. Lower values indicate higher robustness across conditions."@en .


###  https://rsna.org/roadmap/ROADMAP_03580
<https://rsna.org/roadmap/ROADMAP_03580> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03649> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1080/02664763.2016.1174195> ,
                                                   <https://doi.org/10.1177/0962280214537390> ;
                                         rdfs:label "coefficient of variation"@en ,
                                                    "coeficiente de variación"@es ,
                                                    "变异系数"@zh ;
                                         skos:altLabel "CV"@en ,
                                                       "RSD"@en ,
                                                       "relative standard deviation"@en ;
                                         skos:definition "The coefficient of variation is a standardized measure of relative variability, defined as the ratio of the standard deviation to the mean of a dataset. It is dimensionless, allowing direct comparison of variability across datasets with different units or scales. While widely used, it becomes unstable when the mean is near zero and is sensitive to outliers, limiting its interpretability in some contexts."@en ;
                                         skos:exactMatch "http://purl.obolibrary.org/obo/STATO_0000236" .


###  https://rsna.org/roadmap/ROADMAP_03584
<https://rsna.org/roadmap/ROADMAP_03584> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03564> ;
                                         rdfs:label "acceso y calidad de la educación"@es ,
                                                    "education access and quality"@en ,
                                                    "教育机会和质量"@zh ;
                                         skos:definition "Education also influences health and well-being. Education factors include early childhood education and development, graduating from high school, receiving higher education, and even English knowledge and literacy."@en ;
                                         skos:exactMatch "SOHO:100100001" .


###  https://rsna.org/roadmap/ROADMAP_03585
<https://rsna.org/roadmap/ROADMAP_03585> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03564> ;
                                         rdfs:label "entorno vecinal y urbano"@es ,
                                                    "neighborhood and built environment"@en ,
                                                    "社区和建筑环境"@zh ;
                                         skos:definition "As a social determinant of health, the neighborhood and built environment affect health outcomes through quality of housing, access to transportation, access to healthy foods and clean water, air quality inside and outside, and the impact of crime and violence on people who live in the area."@en ;
                                         skos:exactMatch "SOHO:100400001" .


###  https://rsna.org/roadmap/ROADMAP_03586
<https://rsna.org/roadmap/ROADMAP_03586> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03564> ;
                                         rdfs:label "contexto social y comunitario"@es ,
                                                    "social and community context"@en ,
                                                    "社会和社区背景"@zh ;
                                         skos:definition "Social and community context is a social determinant of health, covering the contexts in which people live, study, work, and relax. The sense of belonging to a community, workplace conditions, and discrimination or racism all impact people's health."@en ;
                                         skos:exactMatch "SOHO:10060001" .


###  https://rsna.org/roadmap/ROADMAP_03587
<https://rsna.org/roadmap/ROADMAP_03587> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03564> ;
                                         rdfs:comment "Healthcare cannot be left out of social determinants of health, of course. Access to healthcare is not equal, and people's financial and physical access to healthcare, as well as their understanding of health services and their health, is a major social determinant of health. This includes access to primary care, access to specialty care, health insurance coverage, and health literacy. Health literacy is especially salient as a non-medical social factor, for example, whether people know how to prevent painful kidney stones that can be risky to remove surgically by proper diet and staying hydrated—things people know they “should” do. Yet, it’s difficult to attach importance to it without knowing why."@en ;
                                         rdfs:label "acceso y calidad de la atención médica"@es ,
                                                    "health care access and quality"@en ,
                                                    "医疗保健的可及性和质量"@zh ;
                                         skos:definition "Healthcare access is a social determinant of health. Disparities in healthcare access contribute to inequities in health outcomes among different populations."@en ;
                                         skos:exactMatch "SOHO:100500001" .


###  https://rsna.org/roadmap/ROADMAP_03588
<https://rsna.org/roadmap/ROADMAP_03588> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03564> ;
                                         rdfs:label "economic stability"@en ,
                                                    "estabilidad económica"@es ,
                                                    "经济稳定"@zh ;
                                         rdfs:seeAlso "https://odphp.health.gov/healthypeople/objectives-and-data/browse-objectives/economic-stability"@en ;
                                         skos:definition "Economic stability refers to people's income, socioeconomic status, and cost of living, with factors such as poverty, unemployment or underemployment, food insecurity, and housing instability negatively impacting health."@en ;
                                         skos:exactMatch "SOHO:10090001" .


###  https://rsna.org/roadmap/ROADMAP_03589
<https://rsna.org/roadmap/ROADMAP_03589> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03564> ;
                                         rdfs:label "disability"@en ,
                                                    "discapacidad"@es ,
                                                    "残疾"@zh ;
                                         skos:definition "Disability is a social determinant of health. Disabled people can face health disparities, including a shortened life expectancy and higher rates of preventable chronic conditions."@en .


###  https://rsna.org/roadmap/ROADMAP_03591
<https://rsna.org/roadmap/ROADMAP_03591> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03422> ;
                                         rdfs:label "descriptor geográfico"@es ,
                                                    "geographic descriptor"@en ,
                                                    "地理描述符"@zh ;
                                         skos:definition "An index to the geographic area in which a person lives or works, such as postal code."@en .


###  https://rsna.org/roadmap/ROADMAP_03592
<https://rsna.org/roadmap/ROADMAP_03592> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03591> ;
                                         rdfs:label "código postal"@es ,
                                                    "postal code"@en ,
                                                    "邮政编码"@zh ;
                                         skos:altLabel "PIN code"@en ,
                                                       "ZIP code"@en ,
                                                       "post code"@en ,
                                                       "postcode"@en ;
                                         skos:definition "A postal code is a series of letters and/or digits added to a postal address to identify a specific geographic area."@en ;
                                         skos:exactMatch <http://purl.bioontology.org/ontology/SNOMEDCT/184102003> ,
                                                         <http://purl.obolibrary.org/obo/IAO_0000646> .


###  https://rsna.org/roadmap/ROADMAP_03593
<https://rsna.org/roadmap/ROADMAP_03593> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1016/j.ejmp.2024.104842> ,
                                                   <https://doi.org/10.1148/ryai.230513> ,
                                                   <https://doi.org/10.2214/AJR.25.34340> ;
                                         rdfs:comment "The number of enhanced detection cases for the task is defined as the number of reference-standard positive cases that were detected by AI (i.e., AI true-positive) but missed by the radiologist (i.e., radiologist false-negative)."@en ;
                                         rdfs:label "enhanced detection rate"@en ,
                                                    "tasa de detección mejorada"@es ,
                                                    "提高检测率"@zh ;
                                         skos:altLabel "AI-enhanced detection rate"@en ,
                                                       "EDR"@en ;
                                         skos:definition """The enhanced detection rate is a metric that quantifies the additional diagnostic value contributed by an artificial intelligence system when combined with a human reader. It is defined as the proportion of true positive cases correctly identified by the artificial intelligence but missed by the radiologist, relative to the number of positive cases detected by the radiologist. This measure reflects the incremental gain in sensitivity provided by artificial intelligence beyond the baseline human performance.

                                         EDR = (the number of AI-positive exams not detected by the human reader) / (the number of human-detected positive exams)"""@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03595
<https://rsna.org/roadmap/ROADMAP_03595> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         rdfs:comment "(Kottler N, personal communication)."@en ;
                                         rdfs:label "negative discordance rate"@en ,
                                                    "tasa de discordancia negativa"@es ,
                                                    "阴性不一致率"@zh ;
                                         skos:altLabel "NDR"@en ;
                                         skos:definition "Negative discordance rate = 1 - negative percent agreement"@en ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


