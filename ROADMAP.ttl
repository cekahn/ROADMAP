                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_00059> ;
                                         rdfs:label "SVS"@en ;
                                         skos:altLabel "Slide and Viewable Storage"@en ;
                                         skos:definition "SVS (Slide and Viewable Storage) is a high-resolution image format used primarily in digital pathology to store scanned microscope slides."@en .


