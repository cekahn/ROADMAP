###  https://rsna.org/roadmap/ROADMAP_03632
<https://rsna.org/roadmap/ROADMAP_03632> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03343> ;
                                         dc:source <https://doi.org/10.1038/s41592-023-02151-z> ,
                                                   <https://doi.org/10.1109/34.232073> ;
                                         rdfs:label "95th percentile Hausdorff distance"@en ,
                                                    "distancia de Hausdorff del percentil 95"@es ,
                                                    "第95百分位豪斯多夫距离"@zh ;
                                         skos:altLabel "95HD"@en ,
                                                       "HD95"@en ;
                                         skos:definition "The 95th percentile Hausdorff distance measures the distance threshold below which 95% of the closest point distances between two boundaries fall, reducing sensitivity to extreme outliers. It evaluates boundary alignment while mitigating the influence of isolated segmentation errors. This metric is widely adopted in medical imaging tasks for robust surface distance assessment."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. .


###  https://rsna.org/roadmap/ROADMAP_03633
<https://rsna.org/roadmap/ROADMAP_03633> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03654> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1007/s11547-024-01886-9> ,
                                                   <https://doi.org/10.3115/1073083.1073135> ;
                                         rdfs:label "BLEU"@en ,
                                                    "BLEU"@es ,
                                                    "双语评估替补"@zh ;
                                         skos:altLabel "BLEU"@zh ,
                                                       "BLEU score"@en ,
                                                       "Bilingual Evaluation Understudy"@en ;
                                         skos:definition "BLEU is an automatic, language-independent metric for assessing the quality of machine-generated text, most commonly machine translation, by comparing a candidate output with one or more human reference texts. It aggregates modified n-gram precisions across multiple n-gram sizes and applies a brevity penalty, yielding a standardized, inexpensive corpus-level score that correlates strongly with human judgments. BLEU primarily reflects surface n-gram precision between system and reference texts and does not directly evaluate semantic meaning."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03634
<https://rsna.org/roadmap/ROADMAP_03634> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03654> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://aclanthology.org/W04-1013/> ,
                                                   <https://doi.org/10.1007/s11547-024-01886-9> ;
                                         rdfs:label "ROUGE"@en ,
                                                    "ROUGE"@es ,
                                                    "ROUGE 指标"@zh ;
                                         skos:altLabel "Recall-Oriented Understudy for Gisting Evaluation"@en ;
                                         skos:definition "ROUGE is a set of metrics used to evaluate the quality of machine-generated text, particularly summaries, by comparing it to human-written reference texts. It measures content similarity using overlapping units such as n-grams, sequences, and word pairs, with a primary focus on recall, complemented by precision and F-measure. ROUGE is widely applied for summarization evaluation due to its correlation with human judgment and its ability to incorporate multiple reference summaries."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


###  https://rsna.org/roadmap/ROADMAP_03637
<https://rsna.org/roadmap/ROADMAP_03637> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03641> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_00157> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03322>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_00158> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03339>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_03645> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03314>
                                                         ] ;
                                         rdfs:label "análisis de la curva característica operativa del receptor"@es ,
                                                    "receiver operating characteristic analysis"@en ,
                                                    "受试者工作特征分析"@zh ;
                                         skos:altLabel "ROC"@en ,
                                                       "ROC analysis"@en ,
                                                       "ROC curve"@en ,
                                                       "receiver operating characteristic"@en ,
                                                       "receiver operating characteristic curve"@en ;
                                         skos:definition "Receiver Operating Characteristic (ROC) analysis is a graphical plot that illustrates the diagnostic ability of a binary classifier system as its discrimination threshold varies. It plots the true positive rate (sensitivity) against the false positive rate (1-specificity) at various threshold settings. The area under the ROC curve (AUC) provides an aggregate measure of performance across all classification thresholds."@en .


