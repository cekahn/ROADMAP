                                                    "NRRD"@es ,
                                                    "NRRD"@zh ;
                                         skos:altLabel "Nearly Raw Raster Data"@en ;
                                         skos:definition "A flexible 3D/4D format often favored for segmentation tasks because it handles multidimensional arrays without the overhead of DICOM."@en .


###  https://rsna.org/roadmap/ROADMAP_00134
<https://rsna.org/roadmap/ROADMAP_00134> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_00059> ;
                                         rdfs:label "WSI"@en ,
                                                    "WSI"@es ,
                                                    "WSI"@zh ;
