###  https://rsna.org/roadmap/ROADMAP_03356
<https://rsna.org/roadmap/ROADMAP_03356> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03357> ;
                                         dc:source <https://doi.org/10.1002/9780470317082> ,
                                                   <https://doi.org/10.1117/1.JMI.11.2.024504> ;
                                         rdfs:label "negative likelihood ratio"@en ,
                                                    "razón de verosimilitud negativa"@es ,
                                                    "阴性似然比"@zh ;
                                         skos:altLabel "LR-"@en ,
                                                       "NLR"@en ,
                                                       "negative LR"@en ;
                                         skos:definition """Negative Likelihood Ratio expresses how much less likely a negative test result is in individuals with the condition compared to those without it. It is calculated as the ratio of one minus sensitivity to specificity. Lower values indicate stronger evidence for the absence of the condition.

                                         LR- = (1-sensitivity) / specificity"""@en ;
                                         skos:exactMatch "http://purl.obolibrary.org/obo/STATO_0000410" .


###  https://rsna.org/roadmap/ROADMAP_03357
<https://rsna.org/roadmap/ROADMAP_03357> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap#ROADMAP_03639> ,
                                                         <https://rsna.org/roadmap/ROADMAP_03302> ;
                                         dc:source <https://doi.org/10.1002/9780470317082> ;
                                         rdfs:label "likelihood ratio"@en ,
                                                    "razón de verosimilitud"@es ,
                                                    "似然比"@zh ;
                                         skos:altLabel "LR"@en ;
                                         skos:definition "Likelihood ratio quantifies how much a diagnostic test result changes the odds of having a condition. It compares the probability of a given test result in individuals with the condition to the probability of the same result in those without it. This measure is independent of disease prevalence and can be computed for both positive and negative results."@en ;
                                         skos:exactMatch "http://purl.obolibrary.org/obo/STATO_0000409" .


