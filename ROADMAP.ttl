###  https://rsna.org/roadmap/ROADMAP_00113
<https://rsna.org/roadmap/ROADMAP_00113> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03342> ;
                                         dc:source <https://doi.org/10.1038/s41592-023-02151-z> ,
                                                   <https://doi.org/10.1111/j.1469-8137.1912.tb05611.x> ;
                                         rdfs:label "approximate intersection over union"@en ,
                                                    "intersección aproximada sobre unión"@es ,
                                                    "近似交并比"@zh ;
                                         skos:altLabel "approx IoU"@en ,
                                                       "approx intersection over union"@en ,
                                                       "approximate IoU"@en ;
                                         skos:definition "Approximate intersection over union calculates overlap between simplified geometric representations of structures, such as ellipses or convex hulls, by comparing their intersection with their union. It provides a generalized measure for evaluating predictions that use approximations instead of precise pixel masks. This metric is used in scenarios where an approximate shape suffices for the intended task or computational constraints."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00274> 1. ;
                                         <https://rsna.org/roadmap/ROADMAP_03651> 0. ;
                                         <https://rsna.org/roadmap/ROADMAP_03652> 1. .


