###  https://rsna.org/roadmap/ROADMAP_00155
<https://rsna.org/roadmap/ROADMAP_00155> rdf:type owl:AnnotationProperty ;
                                         rdfs:label "regex"@en .


###  https://rsna.org/roadmap/ROADMAP_00274
<https://rsna.org/roadmap/ROADMAP_00274> rdf:type owl:AnnotationProperty ;
                                         rdfs:comment "This annotation allow one to compare two values to determine which is better."@en ;
                                         rdfs:label "optimum"@en ;
                                         skos:altLabel "optimalValue"@en ;
                                         skos:definition "The \"best\" value of a scalar metric. For example, the optimal value for accuracy is 1."@en ;
                                         rdfs:range xsd:decimal ;
                                         rdfs:domain <https://rsna.org/roadmap/ROADMAP_03302> .


###  https://rsna.org/roadmap/ROADMAP_03626
<https://rsna.org/roadmap/ROADMAP_03626> rdf:type owl:AnnotationProperty ;
                                         rdfs:comment "For example, for RadLex IDs, the pattern \"https://radlex.org/RID/$\" would use value \"RID123\" to generate the URL \"https://radlex.org/RID/RID123\"."@en ;
                                         rdfs:label "pattern"@en ;
                                         skos:definition "Defines the use of a value in a URL."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00155> "RID[0-9]+" .


###  https://rsna.org/roadmap/ROADMAP_03651
<https://rsna.org/roadmap/ROADMAP_03651> rdf:type owl:AnnotationProperty ;
                                         rdfs:label "minimum"@en ;
                                         skos:altLabel "lowerBound"@en ;
                                         skos:definition "The lowest value a scalar metric can attain."@en ;
                                         skos:exactMatch <http://purl.obolibrary.org/obo/STATO_0000667> ;
                                         rdfs:range xsd:decimal ;
                                         rdfs:domain <https://rsna.org/roadmap/ROADMAP_03302> .


###  https://rsna.org/roadmap/ROADMAP_03652
<https://rsna.org/roadmap/ROADMAP_03652> rdf:type owl:AnnotationProperty ;
                                         rdfs:label "maximum"@en ;
                                         skos:altLabel "upperBound"@en ;
                                         skos:definition "The highest value a scalar metric can attain."@en ;
                                         skos:exactMatch <http://purl.obolibrary.org/obo/STATO_0000666> ;
                                         rdfs:range xsd:decimal ;
                                         rdfs:domain <https://rsna.org/roadmap/ROADMAP_03302> .


