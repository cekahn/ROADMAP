                                         rdfs:label "PubMed Central identifier"@en ,
                                                    "PubMed Central标识符"@zh ,
                                                    "identificador de PubMed Central"@es ;
                                         skos:altLabel "PMC ID"@en ,
                                                       "PMCID"@en ,
                                                       "PubMed Central ID"@en ;
                                         skos:definition "The identifer of an article submitted and available through PubMed Central. For example, the identifier \"PMC11304031\" is part of the URL https://pmc.ncbi.nlm.nih.gov/articles/PMC11304031."@en ;
                                         <https://rsna.org/roadmap/ROADMAP_00155> "PMC[0-9]+" ;
