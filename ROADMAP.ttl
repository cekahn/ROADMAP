###  https://rsna.org/roadmap/ROADMAP_03423
<https://rsna.org/roadmap/ROADMAP_03423> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03565> ;
                                         rdfs:label "age"@en ,
                                                    "edad"@es ,
                                                    "年龄"@zh ;
                                         skos:altLabel "patient age"@en ;
                                         skos:definition "Chronological age of an individual."@en ;
                                         skos:exactMatch <http://purl.bioontology.org/ontology/SNOMEDCT/424144002> .


###  https://rsna.org/roadmap/ROADMAP_03424
<https://rsna.org/roadmap/ROADMAP_03424> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03565> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://rsna.org/roadmap/ROADMAP_00631> ;
                                                           owl:someValuesFrom <https://rsna.org/roadmap/ROADMAP_03428>
                                                         ] ;
                                         rdfs:label "sex"@en ,
                                                    "sexo"@es ,
                                                    "性别"@zh ;
                                         skos:altLabel "patient sex"@en ;
                                         skos:definition "The biological classification of an individual as male or female; may specify the sex assigned at birth, recorded sex, or sex parameter for clinical use."@en .


###  https://rsna.org/roadmap/ROADMAP_03425
<https://rsna.org/roadmap/ROADMAP_03425> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03426> ;
                                         rdfs:comment """Birth Sex
                                         Applicable Vocabulary Standard(s)

                                         Birth sex must be coded in accordance with HL7 Version 3 (V3) Standard, Value Sets for AdministrativeGender and NullFlavor attributed as follows:

                                         Female. F
                                         Male. M
                                         Unknown. nullFlavor UNK
                                         Adopted at 45 CFR 170.207(n)"""@en ;
                                         rdfs:label "sex assigned at birth"@en ,
                                                    "sexo asignado al nacer"@es ,
                                                    "出生时指定的性别"@zh ;
                                         skos:altLabel "ASAB"@en ,
                                                       "SAAB"@en ,
                                                       "birth sex"@en ,
                                                       "sex at birth"@en ;
                                         skos:definition "The patient's sex, recorded based on visual inspection of genitalia at birth, as coded in accordance with HL7 Version 3 (V3) Standard."@en .


###  https://rsna.org/roadmap/ROADMAP_03426
<https://rsna.org/roadmap/ROADMAP_03426> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03424> ;
                                         dc:source <http://hl7.org/fhir/StructureDefinition/individual-recordedSexOrGender> ;
                                         rdfs:label "recorded sex or gender"@en ,
                                                    "sexo o género registrado"@es ,
                                                    "记录的性别"@zh ;
                                         skos:altLabel "RSG"@en ,
                                                       "RSoG"@en ,
                                                       "recorded sex"@en ;
                                         skos:definition "From HL7/FHIR: Recorded sex or gender (RSG) information includes the various sex and gender concepts that are often used in existing systems but are known NOT to represent a gender identity, sex parameter for clinical use, or attributes related to sexuality, such as sexual orientation, sexual activity, or sexual attraction. Examples of recorded sex or gender concepts include administrative gender, administrative sex, and sex assigned at birth."@en .


###  https://rsna.org/roadmap/ROADMAP_03427
<https://rsna.org/roadmap/ROADMAP_03427> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_03424> ;
                                         dc:source <http://hl7.org/fhir/StructureDefinition/patient-sexParameterForClinicalUse> ;
                                         rdfs:label "sex parameter for clinical use"@en ,
                                                    "sexo para uso clínico"@es ,
                                                    "临床用途的性别"@zh ;
                                         skos:altLabel "SFCU"@en ,
                                                       "SPCU"@en ,
                                                       "clinical sex"@en ,
                                                       "sex for clinical use"@en ;
                                         skos:definition "The Sex Parameter for Clinical Use (SPCU) is a context-dependent, actionable data element used in healthcare IT to guide clinical decisions, such as selecting appropriate lab reference ranges or diagnostic procedures, based on physiological characteristics (e.g., organ inventory, hormone levels) rather than solely on gender identity or sex assigned at birth."@en .


###  https://rsna.org/roadmap/ROADMAP_03428
<https://rsna.org/roadmap/ROADMAP_03428> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://rsna.org/roadmap/ROADMAP_00662> ;
                                         rdfs:label "sex value"@en ,
                                                    "valor de sexo"@es ,
                                                    "性别值"@zh ;
                                         skos:definition "A patient's sex, which may be female, male, unknown, or not listed."@en ;
                                         skos:exactMatch <http://www.radlex.org/RID/RID5652> .


