#################################################################
#  OPTIONAL: finer-grained mappings via defined subclasses
#
#  'model performance' joins a performance criterion (04043), a metric (03642) and a
#  metric value (03616) with 'has part' (00201). That structure lets several guideline
#  items be reached precisely rather than through the generic class. Two patterns:
#
#  (a) by performance criterion
#
#  :fairnessPerformanceReport rdf:type owl:Class ;
#      owl:equivalentClass [ owl:intersectionOf ( <0XXXX>
#                                                 [ rdf:type owl:Restriction ;
#                                                   owl:onProperty :00201 ;    # has part
#                                                   owl:someValuesFrom <https://rsna.org/roadmap/04064>  # fairness performance
#                                                 ] ) ] ;
#      rdfs:subClassOf [ owl:onProperty :supports ; owl:hasValue <https://rsna.org/roadmap/00307> ] ,  # STARD-AI 23
#                      [ owl:onProperty :supports ; owl:hasValue <https://rsna.org/roadmap/00464> ] ,  # TRIPOD+AI 23a
#                      [ owl:onProperty :supports ; owl:hasValue <https://rsna.org/roadmap/00527> ] ,  # REFINE 5.4
#                      [ owl:onProperty :supports ; owl:hasValue <https://rsna.org/roadmap/00583> ] ,  # DECIDE-AI VIII
#                      [ owl:onProperty :supports ; owl:hasValue <https://rsna.org/roadmap/00258> ] .  # fairness
#
#   Similarly:  calibration performance (04062)  -> TRIPOD+AI 12e (00444), PROBAST+AI eval 4.7 (00653)
#               model drift (00118)              -> MI-CLAIM 18 (00610), REFINE 5.8 (00531)
#               utility (04065)                  -> MI-CLAIM 12 (00604), REFINE 6.3 (00536), TRIPOD+AI 12e (00444)
#               user agreement performance (04067) -> CLAIM 18 (00221), REFINE 5.2 (00525), DECIDE-AI 12 (00585)
#
#  (b) by evaluation partition (03771-03775)
#
#   performance on internal testing partition (03774) -> CLAIM 32 (00235), MINIMAR 4.2 (00563),
#                                                        PROBAST+AI eval 4.1 (00647)
#   performance on external testing partition (03775) -> CLAIM 33 (00236), STARD-AI 29 (00314),
#                                                        MINIMAR 4.3 (00564), TRIPOD+AI 16 (00450)
#
#  If this pattern is adopted, the generic 'model performance' mappings above can be trimmed
#  to those items that ask for performance reporting in general (e.g. CLAIM 28/37, REFINE 5.1).
#################################################################